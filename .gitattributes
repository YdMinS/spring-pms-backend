# Auto detect text files and normalize line endings to LF
* text=auto

# Scripts
*.sh text eol=lf
*.bat text eol=crlf
gradlew text eol=lf
gradlew.bat text eol=crlf

# Source files
*.java text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.json text eol=lf

# Binary files
*.jar binary
*.war binary
*.zip binary
